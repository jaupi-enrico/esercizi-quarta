<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="12.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.codicefiscale.codicefiscale.CodiceFiscaleController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Calcolo Codice Fiscale" />

    <HBox spacing="10">
        <Label text="Nome:" />
        <TextField fx:id="txtNome" prefWidth="200" />
    </HBox>

    <HBox spacing="10">
        <Label text="Cognome:" />
        <TextField fx:id="txtCognome" prefWidth="200" />
    </HBox>

    <HBox spacing="10">
        <Label text="Data di nascita:" />
        <DatePicker fx:id="dateNascita" />
    </HBox>

    <HBox spacing="10">
        <Label text="Sesso:" />
        <RadioButton fx:id="rbMaschio" selected="true" text="M">
         <toggleGroup>
            <ToggleGroup fx:id="sessoGroup" />
         </toggleGroup></RadioButton>
        <RadioButton fx:id="rbFemmina" text="F" toggleGroup="$sessoGroup" />
    </HBox>

    <HBox spacing="10">
        <Label text="Codice Comune:" />
        <TextField fx:id="txtComune" prefWidth="200" />
    </HBox>

    <Button onAction="#onCalcola" text="Calcola Codice Fiscale" />

    <Label text="Codice Fiscale:" />
    <TextField fx:id="txtRisultato" editable="false" prefWidth="250" />

</VBox>
